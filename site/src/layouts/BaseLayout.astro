---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #06080e;
        --card: #0e1622;
        --surface: #131e2e;
        --fg: #c4d8e4;
        --muted: #607888;
        --accent: #2ab4c8;
        --accent-soft: #6ecad8;
        --border: #1a3448;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, sans-serif;
        background: radial-gradient(circle at top, #0f1a28 0%, var(--bg) 55%);
        color: var(--fg);
      }
      main {
        max-width: 1040px;
        margin: 0 auto;
        padding: 72px 24px 96px;
      }
      a { color: var(--accent-soft); }
      .eyebrow {
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.82rem;
        font-weight: 700;
      }
      .hero {
        display: grid;
        gap: 20px;
        margin-bottom: 40px;
      }
      h1 {
        font-size: clamp(2.4rem, 5vw, 4.5rem);
        line-height: 1.05;
        margin: 0;
      }
      .lede {
        max-width: 720px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.7;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin: 40px 0;
      }
      .card {
        border: 1px solid var(--border);
        border-radius: 18px;
        background: linear-gradient(180deg, var(--surface), var(--card));
        padding: 20px;
      }
      .card h2 {
        margin-top: 0;
        font-size: 1.1rem;
      }
      code, pre {
        font-family: "Cascadia Code", ui-monospace, monospace;
      }
      pre {
        background: #08111b;
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 16px;
        overflow-x: auto;
      }
      footer {
        margin-top: 48px;
        color: var(--muted);
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
